/* miniprogram/pages/space-settings/space-settings.wxss */
.section { margin-bottom: 30rpx; }
.section-title { font-size: 28rpx; color: #999; margin-bottom: 16rpx; padding-left: 10rpx; }
.info-card, .invite-card, .danger-card { background: #fff; border-radius: 12rpx; padding: 20rpx 30rpx; }
.invite-card { text-align: center; }
.invite-code { font-size: 48rpx; font-weight: bold; letter-spacing: 8rpx; color: #07c160; margin: 20rpx 0; }
.invite-hint { font-size: 24rpx; color: #999; margin-bottom: 30rpx; }
.info-row { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.info-row:last-child { border-bottom: none; }
.info-label { width: 120rpx; color: #999; font-size: 28rpx; }
.info-value { flex: 1; font-size: 28rpx; color: #333; }
.member-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.member-row:last-child { border-bottom: none; }
.member-avatar { width: 60rpx; height: 60rpx; border-radius: 50%; margin-right: 20rpx; background: #eee; }
.member-name { font-size: 28rpx; color: #333; }
.empty-hint { text-align: center; color: #999; font-size: 26rpx; padding: 20rpx 0; }
.danger-card { }
.danger-hint { font-size: 24rpx; color: #999; margin-bottom: 20rpx; text-align: center; }
.btn-danger { width: 100%; background: #e74c3c; color: #fff; border-radius: 8rpx; padding: 20rpx; font-size: 28rpx; border: none; }
.btn-danger:active { background: #c0392b; }