/* miniprogram/pages/upload/upload.wxss */
.image-picker {
  width: 100%;
  height: 400rpx;
  margin-bottom: 30rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.picker-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

.picker-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-picker {
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  color: #333;
}

.form-input {
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.form-textarea {
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  height: 200rpx;
  font-size: 28rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 40rpx;
}